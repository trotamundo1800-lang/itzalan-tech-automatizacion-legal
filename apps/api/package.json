{
  "name": "@itzalan/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "db:migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "db:migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:migration:generate": "typeorm-ts-node-commonjs migration:generate src/migrations/AutoMigration -d src/database/data-source.ts",
    "test": "npm run test:e2e",
    "test:e2e": "jest --config jest.e2e.config.cjs --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/typeorm": "^11.0.2",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^9.5.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.6",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/pdfkit": "^0.17.6",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
